{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Debug mini_shell",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/mini_shell",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Follow child process after fork",
          "text": "-gdb-set follow-fork-mode child",
          "ignoreFailures": true
        },
        {
          "description": "Keep both parent and child under debugger",
          "text": "-gdb-set detach-on-fork off",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build mini_shell"
    }
  ]
}
